# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.py text eol=lf
*.sh text eol=lf

# Documentation and metadata
*.md text eol=lf
*.txt text eol=lf
*.cff text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf

# Notebooks
*.ipynb text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.xlsx binary
*.xls binary
*.zip binary
*.tar binary
*.gz binary
*.rar binary
*.7z binary